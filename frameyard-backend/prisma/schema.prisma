generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//user schema
model User {
  id              String    @id
  name            String
  email           String    @unique
  isEmailVerified Boolean @default(false)
  phoneNumber     String    @unique
  addressLine     String?
  postalCode      String?
  cityName        String?
  stateName       String?
  countryName     String?
  gender          Gender?
  cart            Cart?
  orders          Order[]
  role            UserRole  @default(CUSTOMER)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("users")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

//Product scehma 
model Product {
  id            String   @id @default(uuid())
  name          String
  description   String?
  brandName     String   @default("FrameYard")
  material      String
  availableColors String[]
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  variants      ProductVariant[]
  images        ProductImage[]
}
model ProductVariant {
  id              String   @id @default(uuid())
  productId       String
  frameSize       String
  mountType       MountType   @default(NONE)
  glassType       GlassType   @default(NONE)
  cartItems       CartItem[]
  price           Decimal @db.Decimal(10,2)
  offerPrice      Decimal? @db.Decimal(10,2)
  priceValidUntil DateTime?
  stockQuantity   Int @default(0)
  createdAt       DateTime @default(now())
  product Product @relation( fields:[productId],references:[id], onDelete: Cascade)
}
enum MountType {
  NONE
  OPTION_1
  OPTION_2
}

enum GlassType {
  NONE
  OPTION_1
  OPTION_2
}
model ProductImage {
  id           String   @id @default(uuid())
  productId    String
  imageUrl     String
  displayOrder Int      @default(1)
  createdAt    DateTime @default(now())
  product Product @relation( fields:[productId],references:[id], onDelete: Cascade)
}
model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User      @relation(fields: [userId], references: [id])
  cartItems CartItem[]
}
model CartItem {
  id         String   @id @default(uuid())
  cartId     String
  variantId  String
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())
  cart        Cart           @relation(fields: [cartId], references: [id])
  variant     ProductVariant @relation(fields: [variantId], references: [id])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
model Order {
  id          String      @id @default(uuid())
  orderNumber  String  ? @unique
  userId      String
  totalAmount Decimal     @db.Decimal(10,2)
  orderStatus OrderStatus @default(PENDING)
  phoneNumber String
  addressLine String
  cityName    String
  stateName   String
  countryName String
  postalCode  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user         User       @relation(fields: [userId],references: [id])
  orderItems   OrderItem[]
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  productId   String?
  variantId   String?
  productName String
  frameSize   String
  mountType   MountType  @default(NONE)
  glassType   GlassType  @default(NONE)
  price       Decimal  @db.Decimal(10,2)
  quantity    Int
  subtotal    Decimal  @db.Decimal(10,2)

  order Order @relation(fields: [orderId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  date      DateTime @default(now())

  @@map("notifications")
}